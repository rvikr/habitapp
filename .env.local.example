# Supabase (required)
# Use the default project URL until a Supabase custom domain is verified and activated.
# After activating a custom Auth/API domain, change this to https://auth.your-domain.example.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Native Google Sign-In for Android (optional locally, required to avoid browser OAuth in APK builds)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# App URL — used as the auth email redirect base (optional for local dev)
# Set to your production URL in cloudbuild.yaml; leave blank locally to use current origin
EXPO_PUBLIC_APP_URL=

# Sentry crash reporting (optional — leave empty to disable)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog analytics (optional — leave empty to disable)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain.example/privacy
EXPO_PUBLIC_TERMS_URL=https://your-domain.example/terms
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://your-domain.example/account-deletion
EXPO_PUBLIC_SUPPORT_EMAIL=support@your-domain.example

# RevenueCat subscriptions (optional in local web/dev, required for native Pro purchases)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your-public-ios-key
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your-public-android-key

# Supabase Edge Function secrets (set with `supabase secrets set`, do not expose in clients)
REVENUECAT_SECRET_API_KEY=your-revenuecat-secret-key
REVENUECAT_WEBHOOK_AUTH_TOKEN=your-shared-webhook-token
