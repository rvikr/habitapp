# Supabase (required)
# Use the default project URL until a Supabase custom domain is verified and activated.
# After activating a custom Auth/API domain, change this to https://auth.your-domain.example.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google OAuth / native Android sign-in.
# Leave EXPO_PUBLIC_GOOGLE_NATIVE_ANDROID_AUTH blank for Expo Go and browser OAuth.
# Production sets this to true in the EAS environment after Google Cloud/Firebase
# has Android OAuth clients for package health.lagan.app and every release SHA-1.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_NATIVE_ANDROID_AUTH=

# Sentry crash reporting (optional — leave empty to disable)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog analytics (optional — leave empty to disable)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain.example/privacy
EXPO_PUBLIC_TERMS_URL=https://your-domain.example/terms
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://your-domain.example/account-deletion
EXPO_PUBLIC_SUPPORT_EMAIL=support@your-domain.example

# RevenueCat subscriptions (optional in local web/dev, required for native Pro purchases)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your-public-ios-key
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your-public-android-key

# Web Push (PWA at /app) — generate VAPID keys once with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY and VAPID_PRIVATE_KEY are set as Supabase function secrets.
# Only the public key needs to be baked into the web bundle.
EXPO_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# Auth redirect for the PWA at /app (add to Supabase Auth allow-list and Google OAuth client)
# After deploying to Vercel: https://lagan.health/app/auth/callback
EXPO_PUBLIC_APP_URL=https://lagan.health/app

# Supabase Edge Function secrets (set with `supabase secrets set`, do not expose in clients)
GEMINI_API_KEY=your-paid-gemini-api-key
# Required in production. AI fails closed unless this exact confirmation is true.
GEMINI_PAID_SERVICE_CONFIRMED=true
REVENUECAT_SECRET_API_KEY=your-revenuecat-secret-key
REVENUECAT_WEBHOOK_AUTH_TOKEN=your-shared-webhook-token
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_SUBJECT=mailto:push@lagan.health
