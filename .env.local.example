# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL — used as the auth email redirect base (optional for local dev)
# Set to your production URL in cloudbuild.yaml; leave blank locally to use current origin
EXPO_PUBLIC_APP_URL=

# Sentry crash reporting (optional — leave empty to disable)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog analytics (optional — leave empty to disable)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain.example/privacy
EXPO_PUBLIC_TERMS_URL=https://your-domain.example/terms
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://your-domain.example/account-deletion
EXPO_PUBLIC_SUPPORT_EMAIL=support@your-domain.example
