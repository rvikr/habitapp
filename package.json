{
  "name": "habbitapp",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "check:auth-config": "node scripts/validate-auth-build-config.mjs",
    "eas-build-pre-install": "node scripts/validate-auth-build-config.mjs --native",
    "check:auth-remote": "node scripts/sync-supabase-auth-config.mjs",
    "sync:auth-remote": "node scripts/sync-supabase-auth-config.mjs --apply",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON tests/unit.test.mjs && node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/activation-presentation.test.mjs tests/activation-analytics.test.mjs tests/activation-analytics-lifecycle.test.mjs tests/analytics-smoke-helper.test.mjs tests/consolidation-validation.test.mjs tests/habit-mutation-coordinator.test.mjs tests/habit-mutation-failure-scope.test.mjs tests/metric-validation-parity.test.mjs tests/screenshot-helper.test.mjs",
    "smoke:first-run": "node scripts/first-run/all-smokes.cjs",
    "smoke:offline-reload": "node scripts/first-run/offline-reload-smoke.cjs",
    "smoke:treatment-quick-start": "node scripts/first-run/treatment-quick-start-smoke.cjs",
    "smoke:routine-resilience": "node scripts/first-run/routine-resilience-smoke.cjs",
    "smoke:treatment-manual": "node scripts/first-run/treatment-manual-habit-smoke.cjs",
    "smoke:activation-dashboard": "node scripts/first-run/activation-dashboard-smoke.cjs",
    "qa:first-run:readiness": "node scripts/first-run/readiness.cjs",
    "qa:first-run:readiness:skip-native-install": "node scripts/first-run/readiness.cjs --skip-native-install",
    "qa:first-run:readiness:web": "node scripts/first-run/readiness.cjs --web-only --skip-native-install",
    "qa:first-run:live-web": "node scripts/first-run/live-web-sanity.cjs",
    "qa:first-run:proof-template": "node scripts/first-run/live-proof.cjs --write-template",
    "qa:first-run:proof-validate": "node scripts/first-run/live-proof.cjs --validate tmp/first-run-live-proof-current.json",
    "generate-assets": "node scripts/generate-assets.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.2.3",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@kingstinct/react-native-healthkit": "^14.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.45.4",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.35",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-health-connect": "^0.1.1",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.9",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "nativewind": "^4.1.23",
    "posthog-react-native": "^4.44.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-health-connect": "^3.5.0",
    "react-native-purchases": "^10.4.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.18.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "playwright": "^1.60.0",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
